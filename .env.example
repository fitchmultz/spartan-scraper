PORT=8741
BIND_ADDR=127.0.0.1
SERVER_READ_HEADER_TIMEOUT_SECONDS=10
SERVER_READ_TIMEOUT_SECONDS=30
SERVER_WRITE_TIMEOUT_SECONDS=60
SERVER_IDLE_TIMEOUT_SECONDS=120
DATA_DIR=.data
USER_AGENT=SpartanScraper/0.1 (+https://github.com/fitchmultz/spartan-scraper)
LOG_LEVEL=info
LOG_FORMAT=text
MAX_CONCURRENCY=4
REQUEST_TIMEOUT_SECONDS=30
REPLAY_REQUEST_TIMEOUT_SECONDS=30
RATE_LIMIT_QPS=2
RATE_LIMIT_BURST=4
MAX_RETRIES=2
RETRY_BASE_MS=400
MAX_RESPONSE_BYTES=10485760
USE_PLAYWRIGHT=0
AUTH_BASIC=
AUTH_BEARER=
AUTH_API_KEY=
AUTH_API_KEY_HEADER=Authorization
AUTH_API_KEY_QUERY=
AUTH_API_KEY_COOKIE=
AUTH_HEADER_X_API_KEY=
AUTH_COOKIE_SESSION=

# API Authentication (for server-side API access)
# When enabled, all API endpoints require X-API-Key header (except /healthz)
# This is auto-enforced whenever BIND_ADDR is non-localhost.
# Generate keys with: spartan auth apikey generate
API_AUTH_ENABLED=false

# Circuit Breaker Configuration (optional)
# Circuit breaker isolates failing hosts to prevent cascading failures
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=3
CIRCUIT_BREAKER_RESET_TIMEOUT_SECONDS=30
CIRCUIT_BREAKER_HALF_OPEN_MAX_REQUESTS=3

# Enhanced Retry Configuration (optional)
RETRY_MAX_DELAY_SECONDS=60
RETRY_BACKOFF_STRATEGY=exponential_jitter
RETRY_STATUS_CODES=429,500,502,503,504

# Adaptive Rate Limiting (optional)
# Dynamically adjusts QPS per host based on server responses
ADAPTIVE_RATE_LIMIT=false
ADAPTIVE_MIN_QPS=0.1
ADAPTIVE_MAX_QPS=2
ADAPTIVE_INCREASE_QPS=0.5
ADAPTIVE_DECREASE_FACTOR=0.5
ADAPTIVE_SUCCESS_THRESHOLD=5
ADAPTIVE_COOLDOWN_MS=1000

# Proxy Configuration (optional)
# Configure proxy for outgoing requests
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=
# Optional proxy pool config file. Leave commented unless you have a real pool file.
# PROXY_POOL_FILE=.data/proxy_pool.json

# Webhook Configuration (optional)
# Enable webhooks for job completion notifications
WEBHOOK_ENABLED=false
WEBHOOK_SECRET=
WEBHOOK_MAX_RETRIES=3
WEBHOOK_BASE_DELAY_MS=1000
WEBHOOK_MAX_DELAY_MS=30000
WEBHOOK_TIMEOUT_MS=30000
WEBHOOK_MAX_CONCURRENT=100

# SSRF Protection (security feature)
# Set to 'true' to allow webhooks to internal/private addresses
# Default: false (internal addresses are blocked for security)
# WARNING: Only enable in trusted environments
WEBHOOK_ALLOW_INTERNAL=false

# Batch Configuration
# Maximum number of URLs per batch request
MAX_BATCH_SIZE=100

# Robots.txt Compliance (optional)
# Enable to respect robots.txt rules (disabled by default)
RESPECT_ROBOTS_TXT=false

# Data Retention Configuration (optional)
# Automatic cleanup of old jobs and crawl states.
# Retention is disabled by default; uncomment limits only when enabling retention.
RETENTION_ENABLED=false
# RETENTION_JOB_DAYS=30
# RETENTION_CRAWL_STATE_DAYS=90
# RETENTION_MAX_JOBS=10000
# RETENTION_MAX_STORAGE_GB=10
# RETENTION_CLEANUP_INTERVAL_HOURS=24
RETENTION_DRY_RUN_DEFAULT=false

# Queue Backend Configuration (optional)
# Choose the job queue backend. Use 'redis' for distributed/multi-instance setups.
# Options: memory, redis
QUEUE_BACKEND=memory

# Redis Configuration (required when QUEUE_BACKEND=redis)
# Redis connection settings for distributed queue and state management
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=spartan:

# Crawl State Backend Configuration (optional)
# Choose the backend for storing crawl state. Use 'redis' for distributed setups.
# Options: sqlite, redis
CRAWL_STATE_BACKEND=sqlite

# pi Bridge Configuration (optional)
# Enables AI-powered extraction through the internal pi bridge.
# Spartan reuses your existing pi auth/models state (PI_CODING_AGENT_DIR, auth.json, models.json).
PI_ENABLED=false
PI_MODE=sdk
PI_NODE_BIN=node
PI_BRIDGE_SCRIPT=tools/pi-bridge/dist/main.js
# Optional JSON config file for route overrides and fixture mode
PI_CONFIG_PATH=
PI_STARTUP_TIMEOUT_SECONDS=10
PI_REQUEST_TIMEOUT_SECONDS=60
# pi itself honors PI_CODING_AGENT_DIR (defaults to ~/.pi/agent)
# PI_CODING_AGENT_DIR=

# Database Exporter Configuration (optional)
# Connection strings for database export destinations.
# These are used as fallback when connection string is not provided in config.
# SPARTAN_POSTGRES_URL=postgres://user:password@localhost:5432/dbname?sslmode=disable
# SPARTAN_MYSQL_URL=user:password@tcp(localhost:3306)/dbname
# SPARTAN_MONGODB_URL=mongodb://user:password@localhost:27017/dbname
