Usage:
  spartan crawl --url <url> [options]

Examples:
  spartan crawl --url https://example.com --max-depth 2 --max-pages 200
  spartan crawl --url https://example.com --headless --wait --out ./out/site.jsonl
  spartan crawl --url https://example.com --pre-processor redact --transformer json-clean
  spartan crawl --url https://example.com --sitemap-url https://example.com/sitemap.xml
  spartan crawl --url https://example.com --sitemap-url https://example.com/sitemap.xml --sitemap-only
  spartan crawl --url https://example.com --include "/blog/**,/products/*"
  spartan crawl --url https://example.com --exclude "/admin/*,/api/**"

Options:
  -auth-basic string
    	Basic auth user:pass
  -auth-profile string
    	Auth profile name
  -cookie value
    	Cookie value (repeatable, name=value)
  -exclude string
    	Comma-separated URL path patterns to exclude (glob syntax, e.g., /admin/*,/api/**)
  -extract-config string
    	Path to inline template JSON
  -extract-template string
    	Extraction template name
  -extract-validate
    	Validate extraction against schema
  -header value
    	Extra header (repeatable, Key: Value)
  -headless
    	Use headless browser
  -include string
    	Comma-separated URL path patterns to include (glob syntax, e.g., /blog/**,/products/*)
  -incremental
    	Use incremental crawling (ETag/Hash)
  -login-pass string
    	Password for login
  -login-pass-selector string
    	CSS selector for password input
  -login-submit-selector string
    	CSS selector for submit button
  -login-url string
    	Login URL for headless auth
  -login-user string
    	Username for login
  -login-user-selector string
    	CSS selector for username input
  -max-depth int
    	Max crawl depth (default 2)
  -max-pages int
    	Max pages to crawl (default 200)
  -out string
    	Output file (JSON)
  -playwright
    	Use Playwright for headless pages
  -post-processor value
    	Pipeline post-processor plugin name (repeatable)
  -pre-processor value
    	Pipeline pre-processor plugin name (repeatable)
  -proxy string
    	Proxy URL (http://, https://, socks5://)
  -proxy-password string
    	Proxy password
  -proxy-username string
    	Proxy username
  -sitemap-only
    	Only crawl URLs from sitemap, not the root URL
  -sitemap-url string
    	Optional URL to sitemap.xml for URL discovery
  -timeout int
    	Request timeout in seconds (default 30)
  -token value
    	Token value (repeatable)
  -token-cookie string
    	Token cookie name (api_key)
  -token-header string
    	Token header name (api_key or bearer override)
  -token-kind string
    	Token kind: bearer|basic|api_key (default "bearer")
  -token-query string
    	Token query param name (api_key)
  -transformer value
    	Output transformer name (repeatable)
  -url string
    	Root URL to crawl
  -wait
    	Wait for completion and write output
  -wait-timeout int
    	Max wait time in seconds (0 = no timeout)
