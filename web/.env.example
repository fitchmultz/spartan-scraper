# API Base URL for the Spartan Scraper web UI.
#
# Development (default): Leave empty to use Vite's dev server proxy.
#   - API requests to /v1/* are proxied to http://localhost:8741
#   - NOTE: This does NOT automatically read the root .env file.
#   - If you change PORT in the root .env, you must set this variable to match (e.g., http://localhost:9000)
#   - This is the recommended setup for local development
#
# Production (separate API server): Set to the full URL of your API server.
#   - Example: VITE_API_BASE_URL=https://api.example.com
#   - Use this when deploying the UI separately from the backend
#
# Production (same-origin): Leave empty if the backend serves the UI.
#   - Example: Go server serves both API and static files
#   - API requests use relative paths to the same origin
VITE_API_BASE_URL=
