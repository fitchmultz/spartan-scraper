{
  "name": "spartan-scraper-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "type-check": "tsc --noEmit",
    "generate": "openapi-ts -i ../api/openapi.yaml -o src/api -c fetch"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@hey-api/client-fetch": "^0.12.0",
    "@hey-api/openapi-ts": "^0.51.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^5.0.2",
    "@biomejs/biome": "^2.2.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.7"
  }
}
